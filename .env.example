# ============================================
# LLM API (火山方舟 - Volcengine Ark)
# ============================================

# 你的火山方舟 API Key
ARK_API_KEY=

# 你在"在线推理 → 自定义推理接入点"里创建的接入点 ID
# 格式类似 ep-2026xxxx-xxxxx (推荐 Doubao Seed 1.6 系列)
LLM_MODEL=doubao-seed-2.0-code

# 火山方舟 API 地址(所有模型统一,兼容 OpenAI 协议)
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# 说明:
# - 后面 Agent 代码用 langchain-openai 的 ChatOpenAI 即可,火山方舟兼容 OpenAI 协议
# - 一个 API Key 通用所有模型:Doubao Seed 1.6 / DeepSeek V3.2 / Kimi K2 / Qwen3 等
# - Week 5 Mock Interviewer 复杂推理可切换 DeepSeek R1 对比

# ============================================
# 可选:LangSmith 追踪(第 6 周会用到)
# ============================================
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key
